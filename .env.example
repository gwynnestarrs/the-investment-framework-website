# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Get this from neon.tech after creating a project
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-here"
# Your Vercel deployment URL (no trailing slash)
NEXTAUTH_URL="https://your-app.vercel.app"

# ─── Stripe ───────────────────────────────────────────────────────────────────
# From Stripe Dashboard → Developers → API Keys (use live keys in production)
STRIPE_SECRET_KEY="sk_live_..."
# From Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Resend (email) ───────────────────────────────────────────────────────────
# From resend.com → API Keys
RESEND_API_KEY="re_..."
# The verified sender email in Resend (must match your verified domain)
EMAIL_FROM="noreply@yourdomain.com"
